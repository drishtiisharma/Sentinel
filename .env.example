# Database
DATABASE_URL=sqlite:///./aiops.db
# Use postgresql for production:
# DATABASE_URL=postgresql://user:password@localhost/aiops

# Gemini AI (optional - removes dependency)
GEMINI_API_KEY=your_gemini_api_key_here

# ML Settings
SIMILARITY_THRESHOLD=0.75
CLUSTERING_EPS=0.5
CLUSTERING_MIN_SAMPLES=2
NOISE_REDUCTION_ENABLED=true

# Alert Generation
REALISTIC_NOISE=true
PATTERN_REPEAT_PROBABILITY=0.3

# Environment
CORS_ORIGINS=["*"]
SERVE_STATIC=true